# Copy this file to `.env` (which is gitignored) and fill in your key.
# `npm start` / `npm run dev` load `.env` automatically if it exists.
# The tool runs fully WITHOUT this: mapping falls back to the heuristic table
# and the AI reasonableness review reports "unavailable". Only set it to enable
# AI account-mapping proposals and the AI reasonableness review.

# Get a key at https://console.anthropic.com/  (the account must have credit balance).
ANTHROPIC_API_KEY=

# Optional — defaults to claude-fable-5.
# ANTHROPIC_MODEL=claude-fable-5
