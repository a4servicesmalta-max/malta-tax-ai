# Copy this file to `.env` (which is gitignored) and fill in a credential.
# `npm start` / `npm run dev` load `.env` automatically if it exists.
# The tool runs fully WITHOUT any of these: mapping falls back to the heuristic
# table and the AI reasonableness review reports "unavailable". Set a credential
# only to enable the AI account-mapping proposal and the reasonableness review.

# --- Preferred: Claude Max / Pro subscription (billed to the plan) ---
# Get it with `claude setup-token` (an sk-ant-oat… token). When set, AI calls go
# through your Max/Pro plan first.
CLAUDE_CODE_OAUTH_TOKEN=

# --- Fallback: pay-per-token API key ---
# Get one at https://console.anthropic.com/ (the account must have a credit
# balance). Used automatically when the Max plan is maxed out (rate-limited) or
# the OAuth token is unusable. Also works on its own if you set only this.
ANTHROPIC_API_KEY=

# Optional — defaults to claude-fable-5.
# ANTHROPIC_MODEL=claude-fable-5
