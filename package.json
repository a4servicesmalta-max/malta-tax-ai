{
  "name": "tax-return-generator",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/server.ts",
    "start": "node --max-old-space-size=400 --env-file-if-exists=.env --import tsx src/server.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "survey": "tsx scripts/survey-template.ts",
    "replay": "tsx scripts/replay.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.1",
    "express": "^4.19.2",
    "jszip": "^3.10.1",
    "multer": "^2.0.1",
    "nodemailer": "^6.10.1",
    "pdf-parse": "^1.1.4",
    "tsx": "^4.16.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.24",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
